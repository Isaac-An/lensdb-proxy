/**
 * @file Firestore Security Rules
 * @core_philosophy This ruleset enforces public read access for lens products, allowing anyone to retrieve product information. Writes (create, update, delete) are disallowed, effectively making the product catalog read-only. Access to Excel import metadata is completely denied, reflecting a decision to restrict access to this administrative data.
 * @data_structure
 *   - `/products/{productId}`: Stores lens product information.
 *   - `/excel_imports/{excelImportId}`: Stores metadata about Excel imports (filename, upload date, record count).
 * @key_security_decisions
 *   - Lens product data is publicly readable, but writes are disabled to maintain catalog integrity.
 *   - Access to Excel import metadata is completely denied, likely to prevent unauthorized access to administrative data.
 *   - No user-specific data is stored, simplifying the access control model.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read lens product information but disallows any writes.
     * @path /products/{productId}
     * @allow (get, list) Anyone can retrieve product data.
     * @deny (create, update, delete) No one can create, update, or delete product data.
     * @principle Products are publicly readable, but writes are forbidden.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Denies all access to Excel import metadata.
     * @path /excel_imports/{excelImportId}
     * @allow None. No one can access Excel import metadata.
     * @deny (get, list, create, update, delete) All requests are denied.
     * @principle Restricts access to potentially sensitive administrative data.
     */
    match /excel_imports/{excelImportId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}