/**
 * @description This ruleset defines access control for product data and Excel import metadata. It prioritizes structural segregation to maintain clear and independent security postures for different types of data. All write operations are forbidden in this prototyping phase.
 * @dataStructure
 * - `/products/{productId}`: Stores product details. Intended to be publicly readable.
 * - `/excel_imports/{excelImportId}`: Stores metadata about Excel imports. Intended to be only writable by authenticated users.
 * @keySecurityDecisions
 * - Public Read Access for Products: The `products` collection is publicly readable to facilitate open access to product information.
 * - No Write Access: All write operations (create, update, delete) are currently disabled to focus on secure data retrieval. Write operations will be enabled once the authorization method is determined.
 * - Structural Segregation: The separation of product data and import metadata allows for distinct access control policies, which is essential for maintaining data integrity and security.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to product details, but disallows any write operations.
     * @path /products/{productId}
     * @allow (get, list): Any user (or no user) can read product data.
     * @deny (create, update, delete): No one can create, update, or delete product data.
     * @principle Public read access for product data.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Restricts access to Excel import metadata. No read or write operations are allowed for prototyping.
     * @path /excel_imports/{excelImportId}
     * @allow None
     * @deny (get, list, create, update, delete): All operations are denied.
     * @principle No access granted during the prototyping phase.
     */
    match /excel_imports/{excelImportId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}