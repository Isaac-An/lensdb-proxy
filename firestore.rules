/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset provides open read access for the `products` collection.
 * Write operations to `/products` are denied, as the error indicates that it is not secure and requires authentication.
 * Write operations to `/excel_imports` are denied, as it should require authentication and authorization.
 *
 * Data Structure:
 * The database contains two top-level collections: `products` and `excel_imports`.
 * `/products/{productId}` stores detailed product information.
 * `/excel_imports/{excelImportId}` stores metadata about Excel import operations.
 *
 * Key Security Decisions:
 * - Listing of products is allowed for all users.
 * - Write operations to products are denied and must require authentication.
 * - No user listing is allowed (to protect user privacy).
 *
 * NOTE: These rules are configured for PROTOTYPING. Data validation is omitted to allow for rapid iteration.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to product details. Write operations are denied.
     * @path /products/{productId}
     * @allow get, list: Any user can read product details.
     * @deny create, update, delete: No one can create, update, or delete products without authentication.
     * @principle Allows public read access for prototyping.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add authentication and authorization checks for product writes.
    }

    /**
     * @description Denies all access to Excel import metadata.
     * @path /excel_imports/{excelImportId}
     * @deny get, list, create, update, delete: No one can read or write Excel import metadata without authentication and authorization.
     * @principle Restricts access to Excel import metadata for security.
     */
    match /excel_imports/{excelImportId} {
      allow get, list, create, update, delete: if false; // TODO: Add authentication and authorization checks for excel import operations.
    }
  }
}