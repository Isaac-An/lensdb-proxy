/**
 * @fileOverview Firestore Security Rules for the lens product database.
 *
 * Core Philosophy:
 * This ruleset focuses on providing open read access to product information
 * while restricting write access to authorized users (currently disabled in this prototype).
 * The data structure segregates product data and Excel import metadata to support
 * different access control needs.
 *
 * Data Structure:
 * - /products/{productId}: Stores lens product details.
 * - /excel_imports/{excelImportId}: Stores metadata about Excel imports.
 *
 * Key Security Decisions:
 * - Product listing is public.
 * - Write operations are currently disabled but are stubbed out for future authorization logic.
 * - No user-specific data is stored, so ownership models are not currently implemented.
 *
 * Future considerations:
 * - The rules are structured to support the addition of user roles or more granular
 *   access controls in the future.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to product information. Write access is currently disabled.
     * @path /products/{productId}
     * @allow (get, list): Any user can read product data.
     * @deny (create, update, delete): No one can write data (currently disabled, future auth will be added).
     * @principle Provides public read access to product information.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add authorization for product creation/modification
    }

    /**
     * @description Allows read access to excel import metadata. Write access is disabled.
     * @path /excel_imports/{excelImportId}
     * @allow (get, list): Any user can read excel import metadata.
     * @deny (create, update, delete): No one can write excel import metadata (disabled, future admin role).
     * @principle Restricts access to excel import metadata.
     */
    match /excel_imports/{excelImportId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add authorization for excel import creation/modification (admin role?)
    }
  }
}