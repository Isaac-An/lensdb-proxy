/**
 * @fileOverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset prioritizes a secure-by-default posture, focusing on preventing unauthorized data access and modification.
 * It currently allows public read access to product data but restricts all write access.
 * All write requests are denied and require a future update to implement appropriate authorization checks.
 *
 * Data Structure:
 * The data is organized into two top-level collections:
 * - `/products/{productId}`: Stores the details of each product.
 * - `/excel_imports/{excelImportId}`: Stores metadata about Excel imports.
 *
 * Key Security Decisions:
 * - Listing products is currently public to facilitate easy browsing, but this may require future refinement.
 * - Write access to product data and excel import data is currently disabled.
 * - No user-specific data is currently stored, so ownership models are not yet implemented.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to product details but denies all write operations.
     * @path /products/{productId}
     * @allow (get, list): Any user can read product details.
     * @deny (create, update, delete): No user can create, update, or delete product details.
     * @principle Allows public read access while restricting write access for now.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Denies all access to excel import metadata.
     * @path /excel_imports/{excelImportId}
     * @deny (get, list, create, update, delete): No user can read or write excel import metadata.
     * @principle Restricts access to excel import metadata.
     */
    match /excel_imports/{excelImportId} {
      allow get, list, create, update, delete: if false;
    }
  }
}