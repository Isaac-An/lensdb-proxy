/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset adopts a public-read, owner-write model for the `products` collection and restricts access to the `excel_imports` collection, allowing only authenticated users to create new import records. No authorization checks are implemented to restrict `excel_imports` to the uploader.
 *
 * Data Structure:
 * - /products/{productId}: Stores product details. Publicly readable, but only authorized users can create, update, or delete.
 * - /excel_imports/{excelImportId}: Stores metadata about Excel imports. Only authenticated users can create new records.
 *
 * Key Security Decisions:
 * - Products are publicly readable to enable easy browsing and discovery.
 * - User listing is implicitly disallowed by the absence of a root-level /users collection.
 * - The rules do NOT validate the specific data types or presence of all fields within the documents, allowing for flexible data shapes during prototyping. Only fields critical for authorization are validated.
 * - No role-based access control is implemented yet; all authenticated users are treated equally for the `excel_imports` collection.
 *
 * Denormalization for Authorization:
 * - The current data model does not require denormalization. If write access to `products` was restricted (e.g., only allow products to be updated by the original uploader), an `ownerId` field should be added to the `Product` entity and the rules updated accordingly.
 *
 * Structural Segregation:
 * - The separation of `products` and `excel_imports` allows for different security postures. Products can be public while import metadata can be restricted.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to product details, but restricts write access to authenticated users.
     * @path /products/{productId}
     * @allow (get, list)
     * @allow (create, update, delete) - only if the user is authenticated.
     * @deny (create, update, delete) - if the user is not authenticated.
     * @principle Enforces public read access with authenticated-user-only writes.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows authenticated users to create new Excel import records.
     * @path /excel_imports/{excelImportId}
     * @allow (create) - only if the user is authenticated.
     * @deny (get, list, update, delete)
     * @principle Enforces authenticated-user-only creation for import records.
     */
    match /excel_imports/{excelImportId} {
      allow get: if false;
      allow list: if false;

      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }
  }
}