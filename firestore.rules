/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes security by default, restricting all access unless explicitly allowed.
 * In this Prototyping phase, we will focus on highly secure authorization but allow flexible data shapes.
 * This allows rapid iteration on the data model while maintaining a strong security posture.
 *
 * Data Structure:
 * The Firestore database contains two top-level collections: `/products/{productId}` and `/excel_imports/{excelImportId}`.
 * The `products` collection stores lens product data.
 * The `excel_imports` collection stores metadata about Excel import operations.
 *
 * Key Security Decisions:
 * - The `products` collection is NOT publicly readable or writable, write operations are denied. This can be changed once ownership is established.
 * - The `excel_imports` collection is NOT publicly readable or writable, write operations are denied. Access to this collection will likely be restricted to admin users, and a suitable access control mechanism will be needed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /products/{productId} collection.
     * @path /products/{productId}
     * @allow (get, list): No one can read this, because it is explicitly denied.
     * @deny (create, update, delete): No one can write to this, because it is explicitly denied.
     * @principle Strict deny-by-default for prototyping.
     */
    match /products/{productId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the /excel_imports/{excelImportId} collection.
     * @path /excel_imports/{excelImportId}
     * @allow (get, list): No one can read this, because it is explicitly denied.
     * @deny (create, update, delete): No one can write to this, because it is explicitly denied.
     * @principle Strict deny-by-default for prototyping.
     */
    match /excel_imports/{excelImportId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}